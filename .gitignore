# API keys and tokens
secrets.json
credentials.json
auth.json
tokens.json

# Node modules (if using Newman or other tools)
node_modules/

# Newman reports
newman/

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
