  "item": [
    {
      "name": "mod-template-engine",
      "item": [
        {
          "name": "get templates",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "id": "414dd856-56d8-440c-ab8a-af34205018ef",
                "exec": [
                  "var keycloakUrl = `https://keycloak-${pm.environment.get('folio')}.${pm.environment.get('domain')}/realms/${pm.environment.get('realm')}/protocol/openid-connect/token`;\r",
                  "\r",
                  "\r",
                  "pm.sendRequest({\r",
                  "    url: keycloakUrl,\r",
                  "    method: 'POST',\r",
                  "    header: {\r",
                  "        'content-type': 'application/x-www-form-urlencoded'\r",
                  "    },\r",
                  "    body: {\r",
                  "        mode: 'urlencoded',\r",
                  "        urlencoded: [\r",
                  "            {key: 'grant_type', value: 'client_credentials'},\r",
                  "            {key: 'client_id', value: pm.environment.get('tenant_client')},\r",
                  "            {key: 'client_secret', value: pm.environment.get('tenant_client_secret')}\r",
                  "        ]\r",
                  "    }\r",
                  "}, (err, res) => pm.environment.set(\"okapi-token\", res.json().access_token));"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "id": "7fa2f794-ddab-4529-9679-53b2e5386a7f",
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "id": "58a16404-e034-49aa-9157-c54c17ac15f7",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "x-okapi-token",
                "value": "{{okapi-token}}",
                "type": "text"
              },
              {
                "key": "x-okapi-tenant",
                "value": "{{realm}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://kong-{{folio}}.{{domain}}/templates",
              "protocol": "https",
              "host": [
                "kong-{{folio}}",
                "{{domain}}"
              ],
