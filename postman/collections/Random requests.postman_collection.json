    {
      "name": "keycloak",
      "item": [
        {
          "name": "configure KC realm",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "id": "40f6b2d1-5a6b-45b0-adf6-aa6d8ee78067",
                "exec": [
                  "var keycloakUrl = `https://keycloak-${pm.environment.get('folio')}.${pm.environment.get('domain')}/realms/master/protocol/openid-connect/token`;\r",
                  "\r",
                  "\r",
                  "pm.sendRequest({\r",
                  "    url: keycloakUrl,\r",
                  "    method: 'POST',\r",
                  "    header: {\r",
                  "        'content-type': 'application/x-www-form-urlencoded'\r",
                  "    },\r",
                  "    body: {\r",
                  "        mode: 'urlencoded',\r",
                  "        urlencoded: [\r",
                  "            {key: 'grant_type', value: 'password'},\r",
                  "            {key: 'client_id', value: 'admin-cli'},\r",
                  "            {key: 'password', value: pm.environment.get('keycloak_password')},\r",
                  "            {key: 'username', value: 'admin'}\r",
                  "        ]\r",
                  "    }\r",
                  "}, (err, res) => pm.environment.set(\"okapi-token\", res.json().access_token));"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "id": "e64f99ef-acb8-4a26-aa18-39e1b91afea5",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{okapi-token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {ADMIN_ACCESS_TOKEN}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"resetPasswordAllowed\": true\n  }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://keycloak-{{folio}}.{{domain}}/admin/realms/{{realm}}",
              "protocol": "https",
              "host": [
                "keycloak-{{folio}}",
                "{{domain}}"
              ],
              "path": [
                "admin",
                "realms",
                "{{realm}}"
              ]
            }
          },
          "response": []
        }
      ],
      "id": "3a10e900-b1ce-403a-8886-74432109fc47"
    },
